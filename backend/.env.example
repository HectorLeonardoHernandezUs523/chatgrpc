# =============================================================================
# .env.example — Plantilla de variables de entorno
# Copiar como .env y completar con los valores reales.
# =============================================================================

# Ruta al archivo de credenciales de Firebase (entorno local)
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# O bien, contenido JSON directo de las credenciales (ideal para Render)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Nombre de la colección en Firestore
FIRESTORE_COLLECTION=messages

# Puerto del servidor gRPC (interno)
GRPC_PORT=50051

# Puerto del servidor HTTP/REST (Render lo asigna automáticamente)
# PORT=5000
